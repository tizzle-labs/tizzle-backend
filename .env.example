# Application
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# Solana Network (devnet or mainnet-beta)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
PROGRAM_ID=2MxgNvaBj3UQJrKqJbmjbXDyWRjgE3XLmmofofgX7SME

# Helius
HELIUS_API_KEY=your_helius_api_key

# Database
DATABASE_URL=postgresql://tizzle:password@localhost:5432/tizzle_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=tizzle-storage
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
